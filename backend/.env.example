# ── Core app config ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development                 # "production" enables secure/sameSite=none cookies

# ── Database ─────────────────────────────────────────────────────────────
MONGO_URI="your_mongodb_connection_string"

# ── Cloudinary (product image storage) ──────────────────────────────────
CLOUDINARY_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_SECRET_KEY="your_cloudinary_api_secret"

# ── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET="generate_a_long_random_string"
ADMIN_EMAIL="admin_email_address"
ADMIN_PASSWORD="admin_password"

# ── Payments ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="your_stripe_secret_key"
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"+

# ── SMTP (MFA/OTP emails — controllers/otpController.js) ──────────────────
EMAILJS_SERVICE_ID=service_f3qdrao
EMAILJS_TEMPLATE_ID=template_77lregn
EMAILJS_PUBLIC_KEY=UbOmzek9MzKNp4tqe
EMAILJS_PRIVATE_KEY=Wb5hNI0TzLEuv2vYo40Ab

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated, no trailing slashes. Must include every deployed
# frontend/admin origin — required because Sentinel cookies need
# credentialed CORS (a wildcard "*" origin is rejected by browsers once
# credentials are involved). Defaults to localhost:5173/5174 if unset.
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174"

# ── Sentinel Layer ───────────────────────────────────────────────────────
# URL of your deployed Sentinel engine's /evaluate endpoint (see
# ../../Sentinel Layer General/DEPLOYMENT.md for how to deploy it, or point
# at a local instance: http://localhost:3001/evaluate).
SENTINEL_API_URL="https://your-sentinel-backend.example.com/evaluate"
# Secret API key from the Sentinel dashboard → API Credentials. Server-side
# only — never expose this to the frontend/admin bundlers.
SENTINEL_API_KEY="your_sentinel_secret_api_key"
# Must match the "Webhook Signing Secret" configured in the Sentinel
# dashboard's Settings, pointing at https://<this-backend>/webhooks/sentinel
SENTINEL_WEBHOOK_SECRET="any_random_string_you_choose"
# Phase 1 of rollout: true = Sentinel scores every action and you can watch
# verdicts in the dashboard, but nothing is enforced (all responses are
# forced to ALLOW). Flip to false once baselines look right. See
# ../../Sentinel Layer General/Sentinel_Integration_Guide.md, "Go Live Safely".
SENTINEL_SHADOW_MODE=true
