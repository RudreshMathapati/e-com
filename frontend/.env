VITE_BACKEND_URL = "http://localhost:4000"

# Required in production (Vercel): frontend and backend are separate deployments,
# so the Sentinel SDK cannot use a relative path. Set this to your deployed
# backend URL + /api/sentinel-proxy in the Vercel frontend environment variables.
# Example: VITE_SENTINEL_PROXY_URL=https://your-backend.railway.app/api/sentinel-proxy
# Leave unset locally — the Vite dev proxy handles it via the relative path fallback.
# VITE_SENTINEL_PROXY_URL=https://your-backend-url.vercel.app/api/sentinel-proxy